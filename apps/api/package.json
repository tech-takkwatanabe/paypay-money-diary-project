{
  "name": "api",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/db/seed.ts",
    "openapi:generate": "bun run src/scripts/generate-openapi.ts",
    "lint": "oxlint && pnpm type-check",
    "type-check": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@hono/swagger-ui": "0.6.1",
    "@hono/zod-openapi": "1.3.0",
    "@hono/zod-validator": "0.7.6",
    "@paypay-money-diary/shared": "workspace:^",
    "bcryptjs": "3.0.3",
    "dotenv": "17.4.2",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.14",
    "ioredis": "5.10.1",
    "jsonwebtoken": "9.0.3",
    "postgres": "3.4.9",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@types/bun": "1.3.12",
    "@types/jsonwebtoken": "9.0.10",
    "@types/pg": "8.20.0",
    "drizzle-kit": "0.31.10",
    "oxlint": "1.61.0",
    "typescript": "6.0.3"
  }
}
